<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!--
      SpendLens logo: magnifying glass with a bar chart inside.
      Built entirely from <path> elements (VectorDrawable does NOT
      support <rect>/<circle>). Centered within the adaptive-icon
      safe zone (~72dp around centre 54,54).
    -->

    <!-- Handle (cyan), drawn first so the lens sits on top of it -->
    <path
        android:strokeColor="#57f1db"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:pathData="M61,61 L78,78" />

    <!-- Outer ring: filled cyan circle, r=23 @ (46,46) -->
    <path
        android:fillColor="#57f1db"
        android:pathData="M46,23 a23,23 0 1,0 0.01,0 z" />

    <!-- Lens glass: white inner circle, r=18 @ (46,46) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,28 a18,18 0 1,0 0.01,0 z" />

    <!-- Bar chart inside the lens (cyan), baseline y=56 -->
    <path
        android:fillColor="#57f1db"
        android:pathData="M37,46 h3.5 v10 h-3.5 z" />
    <path
        android:fillColor="#57f1db"
        android:pathData="M42.5,42 h3.5 v14 h-3.5 z" />
    <path
        android:fillColor="#57f1db"
        android:pathData="M48,38 h3.5 v18 h-3.5 z" />
    <path
        android:fillColor="#57f1db"
        android:pathData="M53.5,34 h3.5 v22 h-3.5 z" />
</vector>
