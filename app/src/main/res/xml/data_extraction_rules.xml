<?xml version="1.0" encoding="utf-8"?>
<!--
  Financial data must never leave the device via cloud/USB backup.
  Exclude everything from both backup transports.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
